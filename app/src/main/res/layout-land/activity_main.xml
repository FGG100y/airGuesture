<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- 左侧：权限列表 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AirGesture"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手势控制服务"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <!-- 相机权限项 -->
        <LinearLayout
            android:id="@+id/permissionCamera"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#4CAF50" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="相机权限"
                android:textSize="14sp"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/cameraStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未授权"
                android:textSize="12sp"
                android:textColor="#FF5722" />
        </LinearLayout>

        <!-- 悬浮窗权限项 -->
        <LinearLayout
            android:id="@+id/permissionOverlay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#4CAF50" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="悬浮窗权限"
                android:textSize="14sp"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/overlayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未授权"
                android:textSize="12sp"
                android:textColor="#FF5722" />
        </LinearLayout>

        <!-- 无障碍权限项 -->
        <LinearLayout
            android:id="@+id/permissionAccessibility"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#4CAF50" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="无障碍权限"
                android:textSize="14sp"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/accessibilityStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未授权"
                android:textSize="12sp"
                android:textColor="#FF5722" />
        </LinearLayout>

        <!-- 说明文字 -->
        <TextView
            android:id="@+id/hintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请获取全部权限后启动服务"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray" />
    </LinearLayout>

    <!-- 右侧：按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:minWidth="140dp">

        <!-- 启动按钮 -->
        <Button
            android:id="@+id/startServiceButton"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:text="启动服务"
            android:textSize="14sp"
            android:visibility="gone"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <!-- 配置按钮 -->
        <Button
            android:id="@+id/configButton"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:text="手势配置"
            android:textSize="14sp"
            android:visibility="gone"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white" />
    </LinearLayout>

</LinearLayout>
